---
import { getYouTubeId, imageUrl, platformLabel } from "../lib/media";
import type { Short } from "../lib/types";

interface Props {
  short: Short;
}

const { short } = Astro.props;
const thumb =
  imageUrl(short.thumbnail, { width: 720, quality: 75 }) ??
  short.thumbnail?.url;

const platform = short.platform;
const handle = short.handle ? `@${short.handle}` : "";
const youTubeId = platform === "youtube" ? getYouTubeId(short.postUrl) : null;

const platformInitial = platform === "instagram"
  ? "IG"
  : platform === "tiktok"
    ? "TT"
    : "YT";
---

<article
  class:list={["short-card", `short-card--${platform}`]}
  data-short
  data-platform={platform}
  data-url={short.postUrl}
  data-youtube={youTubeId ?? ""}
>
  <header class="short-card__head">
    <div class="short-card__avatar" aria-hidden="true">
      <span>{platformInitial}</span>
    </div>
    <div class="short-card__handle">
      <p class="short-card__name">{handle || "Dylan Quinn"}</p>
      <p class="short-card__platform">{platformLabel(platform)}</p>
    </div>
    <span class="short-card__badge" aria-hidden="true">
      {platformLabel(platform)}
    </span>
  </header>

  <div class="short-card__media" data-media>
    {
      thumb && (
        <img
          src={thumb}
          alt={short.title}
          loading="lazy"
          class="short-card__thumb"
        />
      )
    }
    <button
      type="button"
      class="short-card__play"
      data-play
      aria-label={`Play ${platformLabel(platform)} short: ${short.title}`}
    >
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
        <path
          d="M8 5v14l11-7z"
          fill="currentColor"
        />
      </svg>
    </button>
  </div>

  <footer class="short-card__foot">
    <p class="short-card__caption">{short.title}</p>
    <a
      class="short-card__external"
      href={short.postUrl}
      target="_blank"
      rel="noopener noreferrer"
    >
      View on {platformLabel(platform)} <span aria-hidden="true">↗</span>
    </a>
  </footer>
</article>

<style>
  .short-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    border: 1px solid var(--line-soft);
    overflow: hidden;
    transition: transform 220ms ease, border-color 220ms ease;
  }

  .short-card:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 255, 255, 0.14);
  }

  .short-card__head {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--line-soft);
  }

  .short-card__avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2a2a2f, #1a1a1d);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--text);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .short-card__handle {
    flex: 1;
    min-width: 0;
  }

  .short-card__name {
    margin: 0;
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .short-card__platform {
    margin: 1px 0 0;
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }

  .short-card__badge {
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 8px;
  }

  .short-card--instagram .short-card__avatar {
    background:
      conic-gradient(
        from 200deg at 50% 50%,
        #f58529,
        #dd2a7b,
        #8134af,
        #515bd4,
        #f58529
      );
    color: #fff;
  }
  .short-card--tiktok .short-card__avatar {
    background: linear-gradient(135deg, #25f4ee, #fe2c55);
    color: #0a0a0b;
  }
  .short-card--youtube .short-card__avatar {
    background: #ff0033;
    color: #fff;
  }

  .short-card__media {
    position: relative;
    aspect-ratio: 9 / 16;
    background: #000;
    overflow: hidden;
  }

  .short-card__thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .short-card__play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(20, 20, 22, 0.78);
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: var(--text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: transform 200ms ease, background 200ms ease;
  }

  .short-card__play:hover {
    transform: scale(1.06);
    background: rgba(255, 255, 255, 0.92);
    color: #0a0a0b;
  }

  .short-card__foot {
    padding: 14px 16px 18px;
  }

  .short-card__caption {
    margin: 0 0 10px;
    font-size: 13px;
    color: var(--text);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .short-card__external {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
    font-weight: 600;
  }

  .short-card__external:hover {
    color: var(--accent-warm);
  }

  /* Embed states */
  .short-card.is-playing .short-card__play,
  .short-card.is-playing .short-card__thumb {
    display: none;
  }

  .short-card__embed {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .short-card__embed iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
