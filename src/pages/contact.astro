---
import Base from "../layouts/Base.astro";
import { getSiteSettings } from "../lib/queries";

const settings = await getSiteSettings();

const links = [
  settings.contactEmail && {
    label: "Email",
    value: settings.contactEmail,
    href: `mailto:${settings.contactEmail}`,
  },
  settings.instagramHandle && {
    label: "Instagram",
    value: `@${settings.instagramHandle}`,
    href: `https://instagram.com/${settings.instagramHandle}`,
  },
  settings.tiktokHandle && {
    label: "TikTok",
    value: `@${settings.tiktokHandle}`,
    href: `https://tiktok.com/@${settings.tiktokHandle}`,
  },
  settings.youtubeUrl && {
    label: "YouTube",
    value: "Channel",
    href: settings.youtubeUrl,
  },
  settings.linkedinUrl && {
    label: "LinkedIn",
    value: "Profile",
    href: settings.linkedinUrl,
  },
].filter(Boolean) as { label: string; value: string; href: string }[];
---

<Base title={`Contact — ${settings.name}`} description="Get in touch with Dylan Quinn.">
  <main class="container page-section contact">
    <div class="contact__grid">
      <div>
        <p class="eyebrow">Contact</p>
        <h1 class="page-title">Let's work.</h1>
        <p class="contact__intro">
          Available for documentary, branded, and editorial projects.
          The fastest way to reach me is email.
        </p>

        {
          settings.contactEmail && (
            <a class="contact__primary" href={`mailto:${settings.contactEmail}`}>
              {settings.contactEmail}
            </a>
          )
        }
      </div>

      <ul class="contact__links">
        {
          links.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noopener noreferrer">
                <span class="contact__link-label">{link.label}</span>
                <span class="contact__link-value">
                  {link.value}
                  <span aria-hidden="true">↗</span>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </main>
</Base>

<style>
  .contact {
    padding-bottom: 220px;
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(40px, 6vw, 80px);
    align-items: start;
  }

  .contact .eyebrow {
    margin: 0 0 18px;
  }

  .contact__intro {
    margin: 28px 0 36px;
    color: var(--text-soft);
    font-size: clamp(15px, 1.4vw, 17px);
    max-width: 50ch;
  }

  .contact__primary {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 44px);
    color: var(--text);
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
    padding-bottom: 6px;
    transition: color 200ms ease, border-color 200ms ease;
  }

  .contact__primary:hover {
    color: var(--accent-warm);
    border-color: var(--accent-warm);
  }

  .contact__links {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .contact__links li {
    border-top: 1px solid var(--line-soft);
  }

  .contact__links li:last-child {
    border-bottom: 1px solid var(--line-soft);
  }

  .contact__links a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 22px 4px;
    color: var(--text);
    transition: color 200ms ease, padding 200ms ease;
  }

  .contact__links a:hover {
    color: var(--accent-warm);
    padding-left: 12px;
  }

  .contact__link-label {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .contact__link-value {
    font-size: 15px;
  }
  .contact__link-value > span {
    margin-left: 8px;
  }

  @media (max-width: 800px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
