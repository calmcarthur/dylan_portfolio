---
import Base from "../layouts/Base.astro";
import HeroShowcase from "../components/HeroShowcase.astro";
import { getFeaturedProjects, getSiteSettings } from "../lib/queries";

const [settings, featured] = await Promise.all([
  getSiteSettings(),
  getFeaturedProjects(),
]);

const title = `${settings.name} — ${settings.tagline ?? "Sports Media"}`;
---

<Base title={title} description={settings.heroSubcopy}>
  <main class="home">
    <HeroShowcase projects={featured} />

    <div class="home__overlay">
      <div class="home__overlay-inner">
        <p class="eyebrow home__eyebrow">Sports Media — Selected Work</p>
        <h1 class="home__name display">
          {settings.name.split(" ").map((word, i) => (
            <span class="home__name-word" style={`--i:${i}`}>{word}</span>
          ))}
        </h1>
        {
          settings.tagline && (
            <p class="home__tagline">{settings.tagline}</p>
          )
        }
        {
          settings.heroSubcopy && (
            <p class="home__subcopy">{settings.heroSubcopy}</p>
          )
        }
        <div class="home__cta">
          <a href="/work" class="btn btn--primary">View Work</a>
          <a href="/contact" class="btn btn--ghost">Get in Touch</a>
        </div>
      </div>
    </div>
  </main>
</Base>

<style>
  .home {
    position: relative;
  }

  .home__overlay {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    display: flex;
    align-items: flex-start;
    padding: clamp(24px, 5vw, 64px);
    padding-top: clamp(72px, 12vh, 120px);
    padding-bottom: clamp(120px, 16vh, 160px);
  }

  .home__overlay-inner {
    pointer-events: auto;
    width: min(820px, 100%);
  }

  .home__eyebrow {
    margin: 0 0 18px;
    color: rgba(255, 255, 255, 0.7);
  }

  .home__name {
    margin: 0;
    font-size: clamp(72px, 12vw, 188px);
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: var(--text);
    display: flex;
    flex-wrap: wrap;
    column-gap: 0.18em;
    row-gap: 0.05em;
  }

  .home__name-word {
    display: inline-block;
    transform: translateY(28px);
    opacity: 0;
    animation: heroIn 900ms cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
    animation-delay: calc(120ms * var(--i, 0));
  }

  @keyframes heroIn {
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .home__tagline {
    margin: 20px 0 0;
    font-size: clamp(13px, 1.4vw, 17px);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--accent-warm);
    font-weight: 600;
  }

  .home__subcopy {
    margin: 16px 0 0;
    max-width: 52ch;
    font-size: clamp(13px, 1.2vw, 15px);
    color: var(--text-soft);
    line-height: 1.55;
  }

  .home__cta {
    display: inline-flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 36px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 22px;
    border-radius: 999px;
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    transition: background 180ms ease, color 180ms ease,
      border-color 180ms ease, transform 180ms ease;
  }

  .btn--primary {
    background: var(--text);
    color: #0a0a0b;
  }
  .btn--primary:hover {
    background: var(--accent-warm);
    color: #1a1208;
    transform: translateY(-1px);
  }

  .btn--ghost {
    color: var(--text);
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: transparent;
  }
  .btn--ghost:hover {
    border-color: var(--accent-warm);
    color: var(--accent-warm);
  }

  @media (max-height: 720px) {
    .home__name {
      font-size: clamp(64px, 9vw, 136px);
    }
    .home__subcopy {
      display: none;
    }
    .home__cta {
      margin-top: 28px;
    }
  }

  @media (max-width: 720px) {
    .home__overlay {
      padding-top: 56px;
    }
  }
</style>
